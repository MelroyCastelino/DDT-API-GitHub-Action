  "item": [
    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Read expected status from data file\r",
              "var expectedStatus = parseInt(pm.iterationData.get(\"expectedStatus\"));\r",
              "var testCase = pm.iterationData.get(\"testCase\");\r",
              "var name = pm.iterationData.get(\"name\");\r",
              "var email = pm.iterationData.get(\"email\");\r",
              "\r",
              "// Test 1: Status code matches expected\r",
              "pm.test(\"✅ [\" + testCase + \"] Status = \" + expectedStatus, function() {\r",
              "    pm.response.to.have.status(expectedStatus);\r",
              "});\r",
              "\r",
              "// Test 2: Response time check\r",
              "pm.test(\"✅ [\" + testCase + \"] Response fast\", function() {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
              "});\r",
              "\r",
              "// Test 3: Success case specific checks\r",
              "if (expectedStatus === 201) {\r",
              "    pm.test(\"✅ [\" + testCase + \"] Has user ID\", function() {\r",
              "        var json = pm.response.json();\r",
              "        pm.expect(json.id).to.exist;\r",
              "    });\r",
              "}\r",
              "\r",
              "// Log current iteration\r",
              "console.log(\"Iteration:\", pm.info.iteration + 1);\r",
              "console.log(\"Test Case:\", testCase);\r",
              "console.log(\"Name:\", name, \"| Email:\", email);\r",
              "console.log(\"Expected:\", expectedStatus, \"| Actual:\", pm.response.code);\r",
              "console.log(\"---\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
